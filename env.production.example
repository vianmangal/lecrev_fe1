# Leave blank when the frontend is served by nginx on the same origin as the backend.
VITE_LECREV_API_BASE_URL=""

# Server-side API target used by the auth service for GitHub App auto-deploy.
LECREV_API_TARGET="http://127.0.0.1:8080"
LECREV_POSTGRES_DSN="postgres://lecrev:replace-me@127.0.0.1:5432/lecrev?sslmode=disable"
LECREV_PUBLIC_API_URL="https://api.lecrev.example.com"

# GitHub OAuth app credentials.
GITHUB_CLIENT_ID="replace-me"
GITHUB_CLIENT_SECRET="replace-me"

# GitHub App credentials and webhook secret.
GITHUB_APP_ID="replace-me"
GITHUB_PRIVATE_KEY_PATH="/etc/lecrev/frontend-auth/github-app.private-key.pem"
GITHUB_WEBHOOK_SECRET="replace-this-with-a-long-random-secret"
GITHUB_APP_DB_PATH="/var/lib/lecrev/frontend-auth/github-app.sqlite"
